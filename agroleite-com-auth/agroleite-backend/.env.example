# =============================================================
# MooData Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================

# --- Servidor ---
PORT=3000

# --- Banco de Dados (PostgreSQL) ---
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DB?schema=public
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/agroleite_db?schema=public
SHADOW_DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/agroleite_shadow?schema=public

# --- Autenticação JWT ---
# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE_E_ALEATORIA

# --- CORS ---
# URL do frontend permitida a acessar a API em produção.
# Exemplo: https://app.moodata.com.br
FRONTEND_URL=http://localhost:5173
