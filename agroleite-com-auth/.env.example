# =============================================================
# MooData — Docker Compose Environment
# Copie este arquivo para .env na raiz do projeto e preencha.
# NUNCA commite o arquivo .env no repositório.
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=agroleite_admin
POSTGRES_PASSWORD=TROQUE_PELA_SENHA_DO_BANCO
POSTGRES_DB=agroleite_db

# --- Backend ---
DATABASE_URL=postgresql://agroleite_admin:TROQUE_PELA_SENHA_DO_BANCO@db:5432/agroleite_db?schema=public
# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE_E_ALEATORIA
FRONTEND_URL=http://localhost:5173
